{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature Validation State",
  "description": "Tracks validation checkpoints and state for Speckit artifact workflow",
  "type": "object",
  "required": ["feature", "version", "checkpoints", "artifacts"],
  "properties": {
    "feature": {
      "type": "string",
      "description": "Feature directory path (e.g., specs/002-speckit-artifact-validation)"
    },
    "version": {
      "type": "string",
      "description": "Schema version for compatibility",
      "default": "1.0.0"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when state was first created"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of last update"
    },
    "current_stage": {
      "type": "string",
      "enum": ["specify", "clarify", "plan", "tasks", "implement", "completed"],
      "description": "Current workflow stage"
    },
    "checkpoints": {
      "type": "object",
      "description": "Validation checkpoint records",
      "properties": {
        "SPEC_VALIDATED": {
          "$ref": "#/definitions/checkpoint"
        },
        "PLAN_VALIDATED": {
          "$ref": "#/definitions/checkpoint"
        },
        "TASKS_VALIDATED": {
          "$ref": "#/definitions/checkpoint"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "description": "Per-artifact validation state",
      "properties": {
        "spec": {
          "$ref": "#/definitions/artifactState"
        },
        "plan": {
          "$ref": "#/definitions/artifactState"
        },
        "tasks": {
          "$ref": "#/definitions/artifactState"
        }
      },
      "additionalProperties": false
    },
    "validation_config": {
      "type": "object",
      "description": "Validation configuration settings",
      "properties": {
        "max_retries": {
          "type": "integer",
          "default": 3,
          "minimum": 1,
          "maximum": 10
        },
        "agent_model": {
          "type": "string",
          "description": "Model to use for validation agents"
        }
      }
    }
  },
  "definitions": {
    "checkpoint": {
      "type": "object",
      "description": "Validation checkpoint record",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "approved", "rejected", "skipped"],
          "description": "Checkpoint status"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When checkpoint was set"
        },
        "agent": {
          "type": "string",
          "description": "Agent that approved the checkpoint (Momus, Metis, Oracle)"
        },
        "retry_count": {
          "type": "integer",
          "default": 0
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "artifactState": {
      "type": "object",
      "description": "Validation state for a single artifact",
      "properties": {
        "path": {
          "type": "string",
          "description": "Absolute or relative path to artifact file"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "draft", "in_review", "approved", "rejected"],
          "description": "Current validation status"
        },
        "last_modified": {
          "type": "string",
          "format": "date-time",
          "description": "When artifact was last modified"
        },
        "validation_history": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/validationAttempt"
          }
        },
        "hash": {
          "type": "string",
          "description": "SHA256 hash of artifact content for change detection"
        }
      }
    },
    "validationAttempt": {
      "type": "object",
      "description": "Record of a single validation attempt",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "agent": {
          "type": "string"
        },
        "result": {
          "type": "string",
          "enum": ["approved", "rejected", "error"]
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
